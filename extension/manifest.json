{
  "manifest_version": 3,
  "name": "MarketsCoupons Sync",
  "version": "0.1.5",
  "description": "Sincroniza dados de afiliado das prop firms com o admin MarketsCoupons.",
  "permissions": ["storage", "cookies", "activeTab", "scripting"],
  "host_permissions": [
    "https://dashboard.apextraderfunding.com/*",
    "https://bulenox.com/*",
    "https://trader.ftmo.com/*",
    "https://affiliate.ftmo.com/*",
    "https://takeprofittrader.com/*",
    "https://*.takeprofittrader.com/*",
    "https://fundednext.firstpromoter.com/*",
    "https://affiliates.fundednext.com/*",
    "https://partners.earn2trade.com/*",
    "https://hub.the5ers.com/*",
    "https://*.the5ers.com/*",
    "https://*.fundingpips.com/*",
    "https://app.brightfunded.com/*",
    "https://*.brightfunded.com/*",
    "https://*.e8funding.com/*",
    "https://*.e8markets.com/*",
    "https://*.citytradersimperium.com/*",
    "https://*.tradeday.com/*",
    "https://tradeday.postaffiliatepro.com/*",
    "https://qfwhduvutfumsaxnuofa.supabase.co/*"
  ],
  "background": { "service_worker": "background.js" },
  "content_scripts": [
    {
      "matches": [
        "https://dashboard.apextraderfunding.com/aff/member/stats*",
        "https://dashboard.apextraderfunding.com/aff/member/keywords*",
        "https://dashboard.apextraderfunding.com/aff/keywords*"
      ],
      "js": ["config.js", "lib/csv.js", "lib/keywords.js", "content/apex.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://bulenox.com/member/aff/member/stats*",
        "https://bulenox.com/aff/member/stats*",
        "https://bulenox.com/member/aff/stats*",
        "https://bulenox.com/member/aff/member/keywords*",
        "https://bulenox.com/aff/member/keywords*",
        "https://bulenox.com/member/aff/keywords*"
      ],
      "js": ["config.js", "lib/csv.js", "lib/keywords.js", "content/bulenox.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://trader.ftmo.com/affiliate*", "https://trader.ftmo.com/*/affiliate*", "https://affiliate.ftmo.com/*"],
      "js": ["config.js", "content/ftmo.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://takeprofittrader.com/affiliate-dashboard*", "https://*.takeprofittrader.com/affiliate-dashboard*"],
      "js": ["config.js", "lib/csv.js", "content/tpt.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://fundednext.firstpromoter.com/*"],
      "js": ["config.js", "lib/csv.js", "content/fn.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://partners.earn2trade.com/*"],
      "js": ["config.js", "lib/csv.js", "content/e2t.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://hub.the5ers.com/*/affiliate*", "https://hub.the5ers.com/affiliate*"],
      "js": ["config.js", "lib/csv.js", "content/the5ers.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://app.brightfunded.com/affiliate*"],
      "js": ["config.js", "lib/csv.js", "content/brightfunded.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://app.fundingpips.com/affiliate*"],
      "js": ["config.js", "lib/csv.js", "content/fundingpips.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://*.e8markets.com/affiliate*"],
      "js": ["config.js", "lib/csv.js", "content/e8.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://app.citytradersimperium.com/affiliates*"],
      "js": ["config.js", "lib/csv.js", "content/cti.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.tradeday.com/affiliates*", "https://tradeday.com/affiliates*", "https://*.tradeday.com/affiliates*", "https://tradeday.postaffiliatepro.com/*"],
      "js": ["config.js", "lib/csv.js", "content/tradeday.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "MarketsCoupons Sync"
  }
}
