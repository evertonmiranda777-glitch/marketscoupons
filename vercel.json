{
  "functions": {
    "api/render-criativo.js": {
      "memory": 512,
      "maxDuration": 30
    },
    "api/send-email.js": {
      "maxDuration": 60
    },
    "api/cron-bulk-send.js": {
      "maxDuration": 300
    }
  },
  "crons": [
    {
      "path": "/api/cron-promo",
      "schedule": "0 12 */3 * *"
    }
  ],
  "redirects": [
    {
      "source": "/:path(.*)",
      "has": [{ "type": "host", "value": "marketscoupons.com" }],
      "destination": "https://www.marketscoupons.com/:path",
      "permanent": true
    },
    { "source": "/firms/apex.html", "destination": "/apex", "permanent": true },
    { "source": "/firms/bulenox.html", "destination": "/bulenox", "permanent": true },
    { "source": "/firms/ftmo.html", "destination": "/ftmo", "permanent": true },
    { "source": "/firms/tpt.html", "destination": "/tpt", "permanent": true },
    { "source": "/firms/fn.html", "destination": "/fn", "permanent": true },
    { "source": "/firms/e2t.html", "destination": "/e2t", "permanent": true },
    { "source": "/firms/the5ers.html", "destination": "/the5ers", "permanent": true },
    { "source": "/firms/fundingpips.html", "destination": "/fundingpips", "permanent": true },
    { "source": "/firms/brightfunded.html", "destination": "/brightfunded", "permanent": true },
    { "source": "/firms/e8.html", "destination": "/e8", "permanent": true },
    { "source": "/firms/cti.html", "destination": "/cti", "permanent": true },
    { "source": "/firms/tradeday.html", "destination": "/tradeday", "permanent": true },
    { "source": "/t/coupons", "destination": "/?utm_source=telegram&utm_medium=social&utm_campaign=coupons", "permanent": false },
    { "source": "/t/analysis", "destination": "/analysis?utm_source=telegram&utm_medium=social&utm_campaign=analysis", "permanent": false },
    { "source": "/t/gex", "destination": "/gamma?utm_source=telegram&utm_medium=social&utm_campaign=gex", "permanent": false },
    { "source": "/t/calendar", "destination": "/calendar?utm_source=telegram&utm_medium=social&utm_campaign=calendar", "permanent": false },
    { "source": "/t/calendar-alert", "destination": "/calendar?utm_source=telegram&utm_medium=social&utm_campaign=calendar_alert", "permanent": false },
    { "source": "/t/pro", "destination": "/pro?utm_source=telegram&utm_medium=social&utm_campaign=pro", "permanent": false },
    { "source": "/t/loyalty", "destination": "/?utm_source=telegram&utm_medium=social&utm_campaign=loyalty", "permanent": false },
    { "source": "/t/firm/:id", "destination": "/?utm_source=telegram&utm_medium=social&utm_campaign=flash_promo#firm/:id", "permanent": false },
    { "source": "/pt/guides/:slug", "destination": "/guides/:slug", "permanent": false },
    { "source": "/privacy-policy", "destination": "/privacy", "permanent": true },
    { "source": "/privacy_policy", "destination": "/privacy", "permanent": true },
    { "source": "/politica-de-privacidade", "destination": "/privacy", "permanent": true },
    { "source": "/terms-of-service", "destination": "/terms", "permanent": true },
    { "source": "/terms-and-conditions", "destination": "/terms", "permanent": true },
    { "source": "/termos-de-uso", "destination": "/terms", "permanent": true }
  ],
  "routes": [
    { "src": "/blog/(pt|en|es|fr|de|it|ar)/([^/]+)", "dest": "/blog.html" },
    { "src": "/blog/([^/]+)", "dest": "/blog.html" },
    { "src": "/gamma", "dest": "/gex.html" },
    { "src": "/(en|es|fr|de|it|ar)/gamma", "dest": "/gex.html" },
    { "src": "/admin", "dest": "/admin.html" },
    { "src": "/risk-disclosure", "dest": "/risk-disclosure.html" },
    { "src": "/declaracao-de-risco", "dest": "/risk-disclosure.html" },
    { "src": "/go", "dest": "/go.html" },
    { "src": "/go/(.*)", "dest": "/go.html?firm=$1" },
    { "src": "/email-confirm", "dest": "/api/welcome-email" },
    { "src": "/guides/([a-z0-9-]+)", "dest": "/guides/$1.html" },
    { "src": "/(pt|en|es|fr|de|it|ar)/guides/([a-z0-9-]+)", "dest": "/$1/guides/$2.html" },
    { "src": "/(firms|platforms|indicators|compare|calendar|heatmap|analysis|gamma|guides|blog|live|quiz|awards|panel|painel|perfil|loyalty|pro-success|calculator|privacy|terms)", "dest": "/index.html" },
    { "src": "/(en|es|fr|de|it|ar)/(firms|platforms|indicators|compare|calendar|heatmap|analysis|gamma|guides|blog|live|quiz|awards|panel|painel|perfil|loyalty|pro-success|calculator|privacy|terms)", "dest": "/index.html" },
    { "src": "/(en|es|fr|de|it|ar)/(apex|bulenox|ftmo|tpt|fn|e2t|the5ers|fundingpips|brightfunded|e8|cti|tradeday)", "dest": "/index.html" },
    { "src": "/(en|es|fr|de|it|ar)/?$", "dest": "/index.html" },
    { "src": "/(apex|bulenox|ftmo|tpt|fn|e2t|the5ers|fundingpips|brightfunded|e8|cti|tradeday)", "dest": "/index.html" },
    { "src": "/(apex|bulenox|ftmo|tpt|fn|e2t|the5ers|fundingpips|brightfunded|e8|cti|tradeday)-vs-(apex|bulenox|ftmo|tpt|fn|e2t|the5ers|fundingpips|brightfunded|e8|cti|tradeday)", "dest": "/compare/$1-vs-$2.html" },
    { "src": "/(en|es|fr|de|it|ar)/(apex|bulenox|ftmo|tpt|fn|e2t|the5ers|fundingpips|brightfunded|e8|cti|tradeday)-vs-(apex|bulenox|ftmo|tpt|fn|e2t|the5ers|fundingpips|brightfunded|e8|cti|tradeday)", "dest": "/$1/compare/$2-vs-$3.html" }
  ],
  "headers": [
    {
      "source": "/(.*)\\.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/app.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/i18n.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/blog/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/(apex|bulenox|ftmo|tpt|fn|e2t|the5ers|fundingpips|brightfunded|e8|cti|tradeday)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/(en|es|fr|de|it|ar)/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/(en|es|fr|de|it|ar)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/sitemap.xml",
      "headers": [
        { "key": "Content-Type", "value": "application/xml; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    },
    {
      "source": "/robots.txt",
      "headers": [
        { "key": "Content-Type", "value": "text/plain; charset=utf-8" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-DNS-Prefetch-Control", "value": "off" },
        { "key": "X-Powered-By", "value": "" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Cross-Origin-Opener-Policy", "value": "same-origin" },
        { "key": "Permissions-Policy", "value": "accelerometer=(), autoplay=(), browsing-topics=(), camera=(), display-capture=(), encrypted-media=(), fullscreen=(self), geolocation=(), gyroscope=(), interest-cohort=(), magnetometer=(), microphone=(), midi=(), payment=(), serial=(), sync-xhr=(), usb=(), xr-spatial-tracking=()" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" },
        { "key": "Content-Security-Policy", "value": "default-src 'self'; script-src 'self' 'sha256-JnDtM62/532KS6S88RdTxwdpc4486KNP74ZpVhUT+Gk=' 'sha256-M4pXNAHNbzuQiy/Y21EqaID4t5vPIO58eFPyZB4MRxo=' 'sha256-k9qLLok0T8+MGBK5nf/CACCuo3ICqJiztJVmRGBUcao=' 'sha256-BSf+gPYSRXdijbLiO3PEDnT8zjKHIEMUqRgd78iMD0o=' 'sha256-BQsS3bXtlXP3PJWTrVuzxSuIi9DqtQgcPxxPwD9k8js=' 'sha256-4mNvflOuH0gRbpOo2590Lx4gMNlf+gCl5pntXdlKCUg=' 'sha256-220aA14feZYM1VJOzjxVJMTXaANdS5cyA3Y/Xkb0FdI=' 'sha256-qA0chTEjjQHpLxknL1Mhl5bsdy4kGsaNGhUN7oUOtmk=' 'sha256-SXMv3M7KjPK0MbLLjSmgnwQKG8VsI8kKmSUWk5fYL74=' 'sha256-54PMemGbkCIrUywcwyx/34tr1NaYzJkRk0NkbZl9AHQ=' 'sha256-BeZee2e1svA5JmZpzGdaTCkHdRycqDhv5LgKPNr5gaQ=' 'sha256-cqiUllcKsCyAkDC5XO0NmgKjboD+VRBlgBK1SzNZUsU=' 'sha256-oJljWAplKRp3d+YpYN2zp449Mli1M08UmJ1gvwY9NBU=' https://cdn.jsdelivr.net https://cdnjs.cloudflare.com https://www.googletagmanager.com https://www.google-analytics.com https://connect.facebook.net https://s3.tradingview.com https://browser.sentry-cdn.com; script-src-attr 'unsafe-inline'; style-src 'self' 'unsafe-inline'; font-src 'self' data:; img-src 'self' data: https: blob:; connect-src 'self' https://qfwhduvutfumsaxnuofa.supabase.co https://*.supabase.co https://ipinfo.io https://viacep.com.br https://api.zippopotam.us https://*.google-analytics.com https://*.analytics.google.com https://www.googletagmanager.com https://api.anthropic.com https://api.brevo.com https://connect.facebook.net https://www.facebook.com https://*.doubleclick.net https://*.sentry.io https://*.ingest.sentry.io https://browser.sentry-cdn.com https://*.run.app https://*.conversionsapigateway.com https://cdn.jsdelivr.net; frame-src https://www.tradingview-widget.com https://s.tradingview.com https://s3.tradingview.com https://www.tradingview.com https://www.youtube.com; object-src 'none'; base-uri 'self'; form-action 'self'; upgrade-insecure-requests" }
      ]
    }
  ]
}
